# 环境变量示例 - 复制此文件为 .env 并填入实际值
# 数据库
POSTGRES_USER=tohome
POSTGRES_PASSWORD=tohome123
POSTGRES_DB=tohome

# Redis
REDIS_PASSWORD=redis123

# RabbitMQ
RABBITMQ_USER=tohome
RABBITMQ_PASSWORD=rabbit123

# JWT
JWT_SECRET=tohome-jwt-secret-2026

# 微信支付
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key

# 支付宝
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key

# 高德地图
AMAP_KEY=your_amap_key

# 七牛云存储
QINIU_ACCESS_KEY=your_qiniu_access_key
QINIU_SECRET_KEY=your_qiniu_secret_key
QINIU_BUCKET=tohome
QINIU_DOMAIN=cdn.tohome.com

# 短信服务
SMS_ACCESS_KEY=your_sms_access_key
SMS_ACCESS_SECRET=your_sms_access_secret
SMS_SIGN_NAME=到家按摩

# 监控
GRAFANA_PASSWORD=admin123
